<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER"
      prefHeight="600.0"
      prefWidth="900.0"
      spacing="20"
      xmlns="http://javafx.com/javafx/24"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.LoginController"
      stylesheets="@style.css">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <!-- LOGIN CARD -->

    <VBox alignment="CENTER"
          spacing="18"
          prefWidth="380"
          maxWidth="380"
          styleClass="form-container">

        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <!-- TITLE -->

        <Label text="PokéGrading"
               styleClass="title-label">

            <font>
                <Font size="34"/>
            </font>

        </Label>

        <Label text="Login to continue"
               styleClass="subtitle-label"/>

        <!-- EMAIL -->

        <VBox spacing="6" maxWidth="320">

            <Label text="Email"
                   styleClass="form-label"/>

            <TextField fx:id="emailField"
                       promptText="Enter your email"
                       prefHeight="42"/>

        </VBox>

        <!-- PASSWORD -->

        <VBox spacing="6" maxWidth="320">

            <Label text="Password"
                   styleClass="form-label"/>

            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           prefHeight="42"/>

        </VBox>

        <!-- LOGIN BUTTON -->

        <Button text="Login"
                prefWidth="320"
                prefHeight="45"
                onAction="#login"/>

        <!-- CREATE ACCOUNT -->

        <Hyperlink text="Don't have an account? Create one"
                   onAction="#goToRegister"/>

    </VBox>

</VBox>